# ─── AI SAĞLAYICI ───────────────────────────────────────
# groq | openai | anthropic | ollama | mock
AI_PROVIDER=groq

# ─── GROQ ───────────────────────────────────────────────
GROQ_API_KEY=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
# Kullanılabilir modeller:
#   llama-3.3-70b-versatile   (en iyi, önerilen)
#   llama-3.1-8b-instant      (hızlı, hafif)
#   mixtral-8x7b-32768        (uzun bağlam)
#   gemma2-9b-it              (google modeli)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OPENAI (opsiyonel) ─────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# ─── ANTHROPIC (opsiyonel) ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── OLLAMA (opsiyonel, local) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── SUNUCU ─────────────────────────────────────────────
PORT=3400
FRONTEND_ORIGIN=*

# ─── RATE LIMIT ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ─── AI AYARLARI ────────────────────────────────────────
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096
